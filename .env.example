# ══════════════════════════════════════════════════════════════════════════════
# Gwin Bookkeeping LLC — Environment Variables Template
# ══════════════════════════════════════════════════════════════════════════════
#
# HOW TO USE:
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in the real values
# 3. NEVER commit .env.local to GitHub (it's in .gitignore)
# 4. Add these same variables to Cloudflare Pages → Settings → Environment Variables
#
# SECURITY RULES:
# ❌ NEVER commit this file with real values filled in
# ❌ NEVER share secrets via email, Slack, or chat
# ✅ Use Cloudflare Pages environment variables for production
# ✅ Use .env.local for local development only
# ══════════════════════════════════════════════════════════════════════════════

# ── Web3Forms (Contact Form Email Service) ────────────────────────────────
# 1. Go to https://web3forms.com
# 2. Sign up with your email (jerri.Gwin@protonmail.com)
# 3. Click "Create Access Key"
# 4. Paste the key below
WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# ── Site Configuration ────────────────────────────────────────────────────
# The public URL of your website (update after domain purchase)
NEXT_PUBLIC_SITE_URL=https://gwinhbookkeeping.com

# ── Cloudflare Turnstile (Bot Protection) — Optional but recommended ──────
# 1. Go to Cloudflare Dashboard → Turnstile
# 2. Create a new site widget
# 3. Copy the site key (public) and secret key (private)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
# TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# ── Google Analytics 4 — Optional ────────────────────────────────────────
# 1. Go to analytics.google.com
# 2. Create a new property for your website
# 3. Copy the Measurement ID (starts with G-)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google Search Console Verification — Add after domain setup ───────────
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code_here

# ── Node Environment ──────────────────────────────────────────────────────
# Options: development | production | test
NODE_ENV=development
