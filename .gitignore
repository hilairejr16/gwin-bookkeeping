# ══════════════════════════════════════════════════════════════════════════════
# Gwin Bookkeeping LLC — .gitignore
# Files and folders that should NEVER be committed to GitHub.
# ══════════════════════════════════════════════════════════════════════════════

# ── SECURITY CRITICAL — NEVER COMMIT THESE ───────────────────────────────────
.env                  # Local environment variables (contains secrets!)
.env.local            # Local overrides (contains secrets!)
.env.*.local          # Any local env files
.env.production       # Production secrets
*.pem                 # SSL/TLS private keys
*.key                 # Private keys
*.cert                # Certificates
secrets/              # Any secrets folder
credentials.json      # Service account credentials

# ── Node.js Dependencies ─────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js Build Output ──────────────────────────────────────────────────────
.next/
out/
build/

# ── Testing & Coverage ────────────────────────────────────────────────────────
coverage/
.nyc_output

# ── Debug Logs (can contain sensitive info) ───────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── OS Files ──────────────────────────────────────────────────────────────────
.DS_Store             # macOS folder metadata
Thumbs.db             # Windows thumbnail cache
desktop.ini           # Windows desktop config

# ── Editor Files ──────────────────────────────────────────────────────────────
.vscode/settings.json # Personal VSCode settings (share .vscode/extensions.json instead)
.idea/                # JetBrains IDE files
*.swp                 # Vim swap files
*.swo

# ── Cloudflare / Vercel ───────────────────────────────────────────────────────
.vercel
.wrangler/

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Misc ──────────────────────────────────────────────────────────────────────
.cache/
tmp/
temp/
